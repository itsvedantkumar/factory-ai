#!/usr/bin/env bash
set -euo pipefail

FACTORY_ROOT=$(dirname "$(dirname "$(realpath "$0")")")
CONFIG_FILE=${FACTORY_CONFIG_FILE:-$HOME/.config/factory-ai/config}
LEGACY_CONFIG_FILE=$HOME/.config/agent-factory/config
if [[ -f $CONFIG_FILE ]]; then source "$CONFIG_FILE"; elif [[ -f $LEGACY_CONFIG_FILE ]]; then source "$LEGACY_CONFIG_FILE"; fi
RESOURCE_GROUP=${FACTORY_RESOURCE_GROUP:-factory-ai-rg}
VM=${FACTORY_VM:-agent-factory-vm}
NAMESPACE=${FACTORY_SERVICE_BUS:-}
VAULT=${FACTORY_KEY_VAULT:-}
STORAGE=${FACTORY_STORAGE_ACCOUNT:-}
FACTORY_NAME=${FACTORY_NAME:-Factory AI}
FACTORY_PURPOSE=${FACTORY_PURPOSE:-Ship secure reviewed software continuously}

remote() {
  az vm run-command invoke --resource-group "$RESOURCE_GROUP" --name "$VM" \
    --command-id RunShellScript --scripts "$1" --query 'value[0].message' --output tsv
}

usage() {
  printf '%s\n' \
    'Factory AI operator console' \
    'Usage: factory <command>' \
    '  setup' \
    '  configure models' \
    '  models show | set ROLE PROVIDER/MODEL | reset ROLE' \
    '  acp REQUEST.json | extension verify MANIFEST ARTIFACT PUBLIC_KEY' \
    '  github status | connect ORG | transfer OWNER/REPO ORG' \
    '  telegram status | configure | start | stop' \
    '  workspace list | import PATH|OWNER/REPO [--name NAME] | show NAME | remove NAME' \
    '  submit <workspace|owner/repo> <objective>' \
    '  update check | now | status | enable | disable' \
    '  approval approve | deny OBJECTIVE_ID APPROVAL_ID REASON' \
    '  issue <owner/repo> <number>' \
    '  ui' \
    '  init <local-project-path>' \
    '  secret list | set NAME | copy NAME | delete NAME' \
    '  dashboard | status | queue | report | logs | doctor' \
    '  pause | resume'
}

command=${1:-ui}
shift || true

apply_runtime_model() {
  local variable=$1 value=${2:-} mode=${3:-set} script settings
  script="set -euo pipefail; exec 9>/run/lock/factory-ai-config.lock; flock -x 9; first=/etc/agent-factory.env; second=/etc/agent-factory-control.env; backup_first=\$(mktemp); backup_second=\$(mktemp); cp --preserve=mode,ownership \"\$first\" \"\$backup_first\"; cp --preserve=mode,ownership \"\$second\" \"\$backup_second\"; rollback() { install -m 0600 -o root -g root \"\$backup_first\" \"\$first\"; install -m 0600 -o root -g root \"\$backup_second\" \"\$second\"; systemctl restart agent-factory-control agent-factory-worker agent-factory-release || true; rm -f \"\$backup_first\" \"\$backup_second\"; }; trap rollback ERR TERM INT; for file in \"\$first\" \"\$second\"; do tmp=\$(mktemp); grep -v '^${variable}=' \"\$file\" > \"\$tmp\" || true; if [[ '$mode' == set ]]; then printf '${variable}=%s\\n' '$value' >> \"\$tmp\"; fi; install -m 0600 -o root -g root \"\$tmp\" \"\$file\"; rm -f \"\$tmp\"; done; systemctl restart agent-factory-control agent-factory-worker agent-factory-release; systemctl is-active --quiet agent-factory-control agent-factory-worker agent-factory-release; trap - ERR TERM INT; rm -f \"\$backup_first\" \"\$backup_second\""
  printf -v script 'bash -c %q' "$script"
  settings=$(jq -n --arg command "$script" '{commandToExecute:$command}')
  az vm extension set --resource-group "$RESOURCE_GROUP" --vm-name "$VM" --name CustomScript \
    --publisher Microsoft.Azure.Extensions --version 2.1 --force-update --protected-settings "$settings" --output none
}

update_local_model() {
  local variable=$1 value=${2:-} mode=${3:-set} temporary
  mkdir -p "$(dirname "$CONFIG_FILE")"
  temporary=$(mktemp "${CONFIG_FILE}.XXXXXX")
  if [[ -f $CONFIG_FILE ]]; then grep -v "^${variable}=" "$CONFIG_FILE" > "$temporary" || true
  elif [[ -f $LEGACY_CONFIG_FILE ]]; then grep -v "^${variable}=" "$LEGACY_CONFIG_FILE" > "$temporary" || true; fi
  if [[ $mode == set ]]; then printf '%s=%q\n' "$variable" "$value" >> "$temporary"; fi
  chmod 0600 "$temporary"
  mv "$temporary" "$CONFIG_FILE"
}

configure_model_transaction() {
  local variable=$1 value=${2:-} mode=${3:-set}
  MODEL_CONFIG_BACKUP=$(mktemp)
  MODEL_CONFIG_EXISTED=false
  if [[ -f $CONFIG_FILE ]]; then cp "$CONFIG_FILE" "$MODEL_CONFIG_BACKUP"; MODEL_CONFIG_EXISTED=true; fi
  rollback_local_model() {
    if [[ $MODEL_CONFIG_EXISTED == true ]]; then mv "$MODEL_CONFIG_BACKUP" "$CONFIG_FILE"; else rm -f "$CONFIG_FILE" "$MODEL_CONFIG_BACKUP"; fi
  }
  trap rollback_local_model EXIT INT TERM
  update_local_model "$variable" "$value" "$mode"
  apply_runtime_model "$variable" "$value" "$mode"
  rm -f "$MODEL_CONFIG_BACKUP"
  trap - EXIT INT TERM
}

vm_extension_command() {
  local script=$1 settings
  printf -v script 'bash -c %q' "$script"
  settings=$(jq -n --arg command "$script" '{commandToExecute:$command}')
  az vm extension set --resource-group "$RESOURCE_GROUP" --vm-name "$VM" --name CustomScript \
    --publisher Microsoft.Azure.Extensions --version 2.1 --force-update --protected-settings "$settings" --output none
  az vm extension show --resource-group "$RESOURCE_GROUP" --vm-name "$VM" --name CustomScript --instance-view --query 'instanceView.statuses[0].message' --output tsv
}

case "$command" in
  update)
    action=${1:-check}
    case "$action" in
      check)
        current=$(node -p "require('$FACTORY_ROOT/package.json').version")
        latest=$(npm view factory-ai version)
        printf 'Local %s ┬Ę latest %s\n' "$current" "$latest"
        ;;
      now)
        vm_extension_command 'bash /opt/agent-factory/app/bootstrap/auto-update.sh'
        latest=$(npm view factory-ai version)
        current=$(node -p "require('$FACTORY_ROOT/package.json').version")
        if [[ $current != "$latest" ]]; then npm install --global "factory-ai@$latest"; fi
        printf 'Factory AI is current at %s locally and Azure update verification completed.\n' "$latest"
        ;;
      status)
        vm_extension_command 'set -e; printf "timer enabled: "; systemctl is-enabled factory-ai-update.timer; printf "timer active: "; systemctl is-active factory-ai-update.timer; jq -c . /opt/agent-factory/state/runtime-version.json'
        ;;
      enable)
        vm_extension_command 'systemctl enable --now factory-ai-update.timer; systemctl is-active factory-ai-update.timer'
        ;;
      disable)
        vm_extension_command 'systemctl disable --now factory-ai-update.timer; systemctl is-active factory-ai-update.timer >/dev/null && exit 1 || true; printf "automatic updates disabled\n"'
        ;;
      *) printf 'Usage: factory update check | now | status | enable | disable\n' >&2; exit 2 ;;
    esac
    ;;
  approval)
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events exec node "$FACTORY_ROOT/src/approval-cli.js" "$@"
    ;;
  acp)
    request=${1:?ACP request JSON file required}
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events FACTORY_ACP_ENABLED=true exec node "$FACTORY_ROOT/src/acp-cli.js" "$request"
    ;;
  extension)
    [[ ${1:-} == verify ]] || { printf 'Usage: factory extension verify MANIFEST ARTIFACT PUBLIC_KEY\n' >&2; exit 2; }
    exec node "$FACTORY_ROOT/src/extension-cli.js" "${2:?manifest required}" "${3:?artifact required}" "${4:?public key required}"
    ;;
  workspace)
    exec node "$FACTORY_ROOT/src/workspace-cli.js" "$@"
    ;;
  configure)
    area=${1:-models}
    [[ $area == models ]] || { printf 'Supported configuration area: models\n' >&2; exit 2; }
    "$0" models show
    read -r -p 'Role to change (or Enter to leave unchanged): ' role
    [[ -n $role ]] || exit 0
    read -r -p 'New provider/model route (or "default"): ' route
    if [[ $route == default ]]; then exec "$0" models reset "$role"; fi
    exec "$0" models set "$role" "$route"
    ;;
  models)
    action=${1:-show}
    role=${2:-}
    route=${3:-}
    case "$action" in
      show)
        for current in scout planner builder tester debugger reviewer security release; do
          upper=$(printf '%s' "$current" | tr '[:lower:]' '[:upper:]')
          variable="FACTORY_MODEL_${upper}"
          case "$current" in
            scout) default=azureai-textved/factory-gpt-5-4-nano ;;
            tester) default=azureai-responses/gpt-5.4 ;;
            builder) default=azureai-textved/gpt-5.5 ;;
            *) default=azureai-textved/gpt-5.6-sol ;;
          esac
          printf '%-10s %s%s\n' "$current" "${!variable:-$default}" "$([[ -n ${!variable:-} ]] && printf ' (override)' || true)"
        done
        ;;
      set)
        [[ $role =~ ^(scout|planner|builder|tester|debugger|reviewer|security|release)$ ]] || { printf 'Invalid model role\n' >&2; exit 2; }
        node --input-type=module -e "import { validateModelRoute } from 'file://$FACTORY_ROOT/src/routing.js'; validateModelRoute(process.argv[1])" "$route"
        upper=$(printf '%s' "$role" | tr '[:lower:]' '[:upper:]')
        variable="FACTORY_MODEL_${upper}"
        configure_model_transaction "$variable" "$route" set
        printf '%s now routes to %s. Runtime services are healthy.\n' "$role" "$route"
        ;;
      reset)
        [[ $role =~ ^(scout|planner|builder|tester|debugger|reviewer|security|release)$ ]] || { printf 'Invalid model role\n' >&2; exit 2; }
        upper=$(printf '%s' "$role" | tr '[:lower:]' '[:upper:]')
        variable="FACTORY_MODEL_${upper}"
        configure_model_transaction "$variable" "" reset
        printf '%s restored to the versioned default. Runtime services are healthy.\n' "$role"
        ;;
      *) printf 'Usage: factory models show | set ROLE PROVIDER/MODEL | reset ROLE\n' >&2; exit 2 ;;
    esac
    ;;
  telegram)
    action=${1:-status}
    case "$action" in
      status) remote 'systemctl status agent-factory-telegram.service --no-pager -n 20' ;;
      start) remote 'systemctl restart agent-factory-telegram.service; systemctl is-active agent-factory-telegram.service' ;;
      stop) remote 'systemctl stop agent-factory-telegram.service' ;;
      configure)
        read -r -s -p 'Telegram bot token from @BotFather: ' telegram_token; printf '\n'
        read -r -p 'Allowed Telegram chat IDs (comma-separated): ' telegram_chat_ids
        [[ $telegram_chat_ids =~ ^-?[0-9]+(,-?[0-9]+)*$ ]] || { printf 'Invalid Telegram chat ID allowlist\n' >&2; exit 2; }
        ip=$(curl -fsS https://api.ipify.org)
        cleanup_telegram_vault() { az keyvault network-rule remove --name "$VAULT" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; }
        trap cleanup_telegram_vault EXIT
        az keyvault network-rule add --name "$VAULT" --ip-address "$ip/32" --output none
        sleep 5
        az keyvault secret set --vault-name "$VAULT" --name telegram-bot-token --value "$telegram_token" --output none
        az keyvault secret set --vault-name "$VAULT" --name telegram-allowed-chat-ids --value "$telegram_chat_ids" --output none
        unset telegram_token
        remote 'systemctl restart agent-factory-telegram.service; systemctl is-active agent-factory-telegram.service'
        ;;
      *) printf 'Unknown telegram action: %s\n' "$action" >&2; exit 2 ;;
    esac
    ;;
  issue)
    repo=${1:?repository owner/name required}
    number=${2:?issue number required}
    [[ $repo =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ && $number =~ ^[0-9]+$ ]] || { printf 'Invalid repository or issue number\n' >&2; exit 2; }
    issue=$(gh issue view "$number" --repo "$repo" --json title,body,url)
    title=$(jq -r .title <<<"$issue")
    body=$(jq -r .body <<<"$issue")
    url=$(jq -r .url <<<"$issue")
    objective="/goal Resolve GitHub issue #$number: $title"
    objective+=$'\n\n'
    objective+="$body"
    objective+=$'\n\nSource: '
    objective+="$url"
    exec "$0" submit "$repo" "$objective"
    ;;
  ui)
    if [[ ! -f $CONFIG_FILE && ! -f $LEGACY_CONFIG_FILE ]]; then
      "$0" setup
      exec "$0" ui
    fi
    version=$(node -p "require('$FACTORY_ROOT/package.json').version")
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch=$(uname -m)
    [[ $arch == x86_64 ]] && arch=amd64
    [[ $arch == aarch64 ]] && arch=arm64
    cache="$HOME/.cache/factory-ai/$version"
    binary="$cache/factory-ui-$os-$arch"
    if [[ ! -x $binary ]]; then
      mkdir -p "$cache"
      base="https://github.com/itsvedantkumar/factory-ai/releases/download/v$version"
      if curl -fsSL "$base/factory-ui-$os-$arch" -o "$binary.tmp" && curl -fsSL "$base/checksums.txt" -o "$cache/checksums.txt"; then
        expected=""
        while read -r checksum asset; do [[ $asset == "factory-ui-$os-$arch" ]] && expected=$checksum; done < "$cache/checksums.txt"
        actual=""
        if command -v shasum >/dev/null; then actual=$(shasum -a 256 "$binary.tmp"); actual=${actual%% *};
        elif command -v sha256sum >/dev/null; then actual=$(sha256sum "$binary.tmp"); actual=${actual%% *}; fi
        if [[ -n $expected && $actual == "$expected" ]] && gh attestation verify "$binary.tmp" --repo itsvedantkumar/factory-ai >/dev/null 2>&1; then mv "$binary.tmp" "$binary"; chmod 0755 "$binary"; else rm -f "$binary.tmp"; fi
      fi
    fi
    if [[ -x $binary ]]; then
      FACTORY_STORAGE_ACCOUNT="$STORAGE" FACTORY_NAME="$FACTORY_NAME" FACTORY_PURPOSE="$FACTORY_PURPOSE" exec "$binary"
    fi
    printf 'Verified Factory TUI binary is unavailable for %s/%s. Check GitHub release assets and `gh auth status`.\n' "$os" "$arch" >&2
    exit 1
    ;;
  setup)
    for dependency in az gh jq curl ssh-keygen node; do command -v "$dependency" >/dev/null || { printf 'Missing dependency: %s\n' "$dependency" >&2; exit 1; }; done
    choices=$(mktemp)
    trap 'rm -f "$choices"' EXIT
    node "$FACTORY_ROOT/src/setup-menu.js" "$choices"
    provider=$(jq -r .provider "$choices")
    factory_name=$(jq -r .factoryName "$choices")
    factory_purpose=$(jq -r .factoryPurpose "$choices")
    location=$(jq -r .location "$choices")
    enterprise_org=$(jq -r .githubOrg "$choices")
    aws_region=$(jq -r .awsRegion "$choices")
    bedrock_builder=$(jq -r .bedrockBuilderModel "$choices")
    deploy_now=$(jq -r .deployNow "$choices")
    telegram=$(jq -r .telegram "$choices")
    az account show --query '{subscription:name,state:state}' --output table
    gh auth status
    az group show --name "$RESOURCE_GROUP" --output none 2>/dev/null || az group create --name "$RESOURCE_GROUP" --location "$location" --output none
    key=${FACTORY_SSH_KEY:-$HOME/.ssh/agent-factory-azure}
    [[ -f $key ]] || ssh-keygen -t ed25519 -f "$key" -N "" -C agent-factory-azure
    operator=$(az ad signed-in-user show --query id --output tsv)
    deployment=$(az deployment group create --name agent-factory-setup --resource-group "$RESOURCE_GROUP" --template-file "$FACTORY_ROOT/infra/main.bicep" --parameters adminSshKey="$(< "$key.pub")" operatorObjectId="$operator" --output json)
    vault=$(jq -r '.properties.outputs.keyVaultName.value' <<<"$deployment")
    namespace=$(jq -r '.properties.outputs.serviceBusNamespace.value' <<<"$deployment")
    storage=$(jq -r '.properties.outputs.storageAccount.value' <<<"$deployment")
    VAULT=$vault
    NAMESPACE=$namespace
    mkdir -p "$(dirname "$CONFIG_FILE")"
    {
      printf 'FACTORY_RESOURCE_GROUP=%q\n' "$RESOURCE_GROUP"
      printf 'FACTORY_VM=%q\n' agent-factory-vm
      printf 'FACTORY_SERVICE_BUS=%q\n' "$namespace"
      printf 'FACTORY_KEY_VAULT=%q\n' "$vault"
      printf 'FACTORY_STORAGE_ACCOUNT=%q\n' "$storage"
      printf 'FACTORY_NAME=%q\n' "$factory_name"
      printf 'FACTORY_PURPOSE=%q\n' "$factory_purpose"
    } > "$CONFIG_FILE"
    chmod 0600 "$CONFIG_FILE"
    ip=$(curl -fsS https://api.ipify.org)
    cleanup_setup_vault() { az keyvault network-rule remove --name "$vault" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; rm -f "$choices"; }
    trap cleanup_setup_vault EXIT
    az keyvault network-rule add --name "$vault" --ip-address "$ip/32" --output none
    sleep 10
    github_token=$(gh auth token)
    az keyvault secret set --vault-name "$vault" --name github-token --value "$github_token" --output none
    unset github_token
    if [[ -n $enterprise_org ]]; then
      gh api "orgs/$enterprise_org" --silent
      az keyvault secret set --vault-name "$vault" --name github-enterprise-org --value "$enterprise_org" --output none
    fi
    if [[ $provider == azure || $provider == both ]]; then
      read -r -p 'Azure OpenAI-compatible base URL: ' azure_base
      read -r -s -p 'Azure API key: ' azure_key; printf '\n'
      read -r -p 'Separate GPT-5.4 base URL (Enter to reuse): ' azure_small_base
      [[ -n $azure_small_base ]] || azure_small_base=$azure_base
      read -r -s -p 'Separate GPT-5.4 key (Enter to reuse): ' azure_small_key; printf '\n'
      [[ -n $azure_small_key ]] || azure_small_key=$azure_key
      az keyvault secret set --vault-name "$vault" --name azure-primary-base-url --value "$azure_base" --output none
      az keyvault secret set --vault-name "$vault" --name azure-primary-api-key --value "$azure_key" --output none
      az keyvault secret set --vault-name "$vault" --name azure-small-base-url --value "$azure_small_base" --output none
      az keyvault secret set --vault-name "$vault" --name azure-small-api-key --value "$azure_small_key" --output none
      unset azure_key azure_small_key
    fi
    if [[ $provider == bedrock || $provider == both ]]; then
      read -r -p 'AWS access key ID: ' aws_access_key
      read -r -s -p 'AWS secret access key: ' aws_secret_key; printf '\n'
      read -r -s -p 'AWS session token (optional): ' aws_session_token; printf '\n'
      az keyvault secret set --vault-name "$vault" --name aws-access-key-id --value "$aws_access_key" --output none
      az keyvault secret set --vault-name "$vault" --name aws-secret-access-key --value "$aws_secret_key" --output none
      [[ -n $aws_session_token ]] && az keyvault secret set --vault-name "$vault" --name aws-session-token --value "$aws_session_token" --output none
      unset aws_access_key aws_secret_key aws_session_token
    fi
    if [[ $telegram == true ]]; then
      read -r -s -p 'Telegram bot token from @BotFather: ' telegram_token; printf '\n'
      read -r -p 'Allowed Telegram chat IDs (comma-separated): ' telegram_chat_ids
      [[ $telegram_chat_ids =~ ^-?[0-9]+(,-?[0-9]+)*$ ]] || { printf 'Invalid Telegram chat ID allowlist\n' >&2; exit 2; }
      az keyvault secret set --vault-name "$vault" --name telegram-bot-token --value "$telegram_token" --output none
      az keyvault secret set --vault-name "$vault" --name telegram-allowed-chat-ids --value "$telegram_chat_ids" --output none
      unset telegram_token
    fi
    printf 'Azure foundation and credential vault ready. Config: %s\n' "$CONFIG_FILE"
    if [[ $deploy_now == true ]]; then
      source_ref=$(gh api repos/itsvedantkumar/factory-ai/commits/main --jq .sha)
      parameters=(KEY_VAULT_NAME "$vault" SERVICE_BUS_NAMESPACE "$namespace" FACTORY_STORAGE_ACCOUNT "$storage" FACTORY_NAME "$factory_name" FACTORY_PURPOSE "$factory_purpose" SOURCE_REPOSITORY itsvedantkumar/factory-ai SOURCE_REF "$source_ref")
      if [[ $provider == bedrock ]]; then
        parameters+=(AWS_REGION "$aws_region")
        for role in SCOUT PLANNER BUILDER TESTER DEBUGGER REVIEWER SECURITY RELEASE; do parameters+=("FACTORY_MODEL_$role" "bedrock/$bedrock_builder"); done
      elif [[ $provider == both ]]; then
        parameters+=(AWS_REGION "$aws_region" FACTORY_MODEL_BUILDER "bedrock/$bedrock_builder")
      fi
      az vm run-command invoke --resource-group "$RESOURCE_GROUP" --name agent-factory-vm --command-id RunShellScript \
        --scripts @"$FACTORY_ROOT/bootstrap/deploy-runtime.sh" --parameters "${parameters[@]}" --output none
      printf 'Runtime deployed. Run: factory doctor && factory dashboard\n'
    fi
    ;;
  github)
    action=${1:-status}
    case "$action" in
      status)
        gh auth status
        printf 'Organizations:\n'
        gh api user/orgs --jq '.[].login'
        ;;
      connect)
        org=${2:?Enterprise organization required}
        gh api "orgs/$org" --jq '{login,plan:.plan.name}'
        token=$(gh auth token)
        ip=$(curl -fsS https://api.ipify.org)
        cleanup_github_vault() { az keyvault network-rule remove --name "$VAULT" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; }
        trap cleanup_github_vault EXIT
        az keyvault network-rule add --name "$VAULT" --ip-address "$ip/32" --output none
        sleep 5
        az keyvault secret set --vault-name "$VAULT" --name github-token --value "$token" --output none
        az keyvault secret set --vault-name "$VAULT" --name github-enterprise-org --value "$org" --output none
        unset token
        printf 'Connected organization %s. Restart release/worker services after credential changes.\n' "$org"
        ;;
      transfer)
        repo=${2:?OWNER/REPO required}
        org=${3:?Enterprise organization required}
        gh api --method POST "repos/$repo/transfer" -f new_owner="$org" --silent
        printf 'Transfer requested: %s -> %s. Update submit paths after GitHub completes it.\n' "$repo" "$org"
        ;;
      *) printf 'Unknown github action: %s\n' "$action" >&2; exit 2 ;;
    esac
    ;;
  secret)
    action=${1:-list}
    name=${2:-}
    ip=$(curl -fsS https://api.ipify.org)
    cleanup_vault_rule() { az keyvault network-rule remove --name "$VAULT" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; }
    trap cleanup_vault_rule EXIT
    az keyvault network-rule add --name "$VAULT" --ip-address "$ip/32" --output none
    sleep 5
    case "$action" in
      list) az keyvault secret list --vault-name "$VAULT" --query '[].{name:name,updated:attributes.updated}' --output table ;;
      set)
        [[ $name =~ ^[A-Za-z0-9-]+$ ]] || { printf 'Valid secret name required\n' >&2; exit 2; }
        read -r -s -p "Value for $name: " value
        printf '\n'
        az keyvault secret set --vault-name "$VAULT" --name "$name" --value "$value" --output none
        unset value
        printf 'Stored %s in Azure Key Vault.\n' "$name"
        ;;
      copy)
        [[ $name =~ ^[A-Za-z0-9-]+$ ]] || { printf 'Valid secret name required\n' >&2; exit 2; }
        az keyvault secret show --vault-name "$VAULT" --name "$name" --query value --output tsv | pbcopy
        printf 'Copied %s to clipboard without printing it.\n' "$name"
        ;;
      delete)
        [[ $name =~ ^[A-Za-z0-9-]+$ ]] || { printf 'Valid secret name required\n' >&2; exit 2; }
        az keyvault secret delete --vault-name "$VAULT" --name "$name" --output none
        printf 'Soft-deleted %s.\n' "$name"
        ;;
      *) printf 'Unknown secret action: %s\n' "$action" >&2; exit 2 ;;
    esac
    ;;
  init)
    target=${1:?local project path required}
    [[ -d $target ]] || { printf 'Project directory does not exist: %s\n' "$target" >&2; exit 2; }
    context=$(node --input-type=module -e "import { initializeProject } from 'file://$FACTORY_ROOT/src/project-init.js'; console.log(await initializeProject(process.argv[1], '$FACTORY_ROOT/templates'))" "$target")
    printf 'Initialized %s\nShared runtime memory remains on Azure; repo context lives in .agent-factory/.\n' "$context"
    ;;
  submit)
    repo=${1:?workspace name or repository owner/name required}
    shift
    objective=${*:?objective required}
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events exec node "$FACTORY_ROOT/src/submit-cli.js" "$repo" "$objective"
    ;;
  dashboard|status)
    remote 'sudo -u factory env $(xargs < /etc/agent-factory-control.env) node /opt/agent-factory/app/src/dashboard.js'
    ;;
  queue)
    az servicebus queue list --resource-group "$RESOURCE_GROUP" --namespace-name "$NAMESPACE" \
      --query '[].{queue:name,active:countDetails.activeMessageCount,deadLetter:countDetails.deadLetterMessageCount}' --output table
    ;;
  report)
    remote 'node -e '\''const fs=require("fs"),p="/opt/agent-factory/state/reports";const f=fs.readdirSync(p).filter(x=>x.endsWith(".md")).sort().at(-1);process.stdout.write(fs.readFileSync(`${p}/${f}`,"utf8"))'\'''
    ;;
  logs)
    remote 'journalctl -u agent-factory-control -u agent-factory-worker -u agent-factory-release --since "1 hour ago" --no-pager -n 250'
    ;;
  doctor)
    remote 'systemctl is-active agent-factory-control agent-factory-worker agent-factory-release; systemctl is-enabled agent-factory-reporter.timer; docker ps --format "{{.Names}} {{.Status}}"; findmnt /opt/agent-factory/state; df -h /opt/agent-factory/state; free -h'
    ;;
  pause)
    remote 'systemctl stop agent-factory-worker agent-factory-release'
    ;;
  resume)
    remote 'systemctl start agent-factory-worker agent-factory-release; systemctl is-active agent-factory-worker agent-factory-release'
    ;;
  help|-h|--help) usage ;;
  *) usage >&2; exit 2 ;;
esac
