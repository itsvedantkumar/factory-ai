#!/usr/bin/env bash
set -euo pipefail

FACTORY_ROOT=$(dirname "$(dirname "$(realpath "$0")")")
CONFIG_FILE=${FACTORY_CONFIG_FILE:-$HOME/.config/factory-ai/config}
SETUP_STATE_FILE=${FACTORY_SETUP_STATE_FILE:-$(dirname "$CONFIG_FILE")/setup-state.json}
LEGACY_CONFIG_FILE=$HOME/.config/agent-factory/config
if [[ -f $CONFIG_FILE ]]; then source "$CONFIG_FILE"; elif [[ -f $LEGACY_CONFIG_FILE ]]; then source "$LEGACY_CONFIG_FILE"; fi
RESOURCE_GROUP=${FACTORY_RESOURCE_GROUP:-factory-ai-rg}
VM=${FACTORY_VM:-agent-factory-vm}
NAMESPACE=${FACTORY_SERVICE_BUS:-}
VAULT=${FACTORY_KEY_VAULT:-}
STORAGE=${FACTORY_STORAGE_ACCOUNT:-}
FACTORY_NAME=${FACTORY_NAME:-Factory AI}
FACTORY_PURPOSE=${FACTORY_PURPOSE:-Ship secure reviewed software continuously}

config_ready() { [[ -n $STORAGE && -n $NAMESPACE && -n $VAULT ]]; }
setup_phase() { [[ -f $SETUP_STATE_FILE ]] && jq -r '.phase // "unknown"' "$SETUP_STATE_FILE" 2>/dev/null || printf 'legacy\n'; }

remote() {
  az vm run-command invoke --resource-group "$RESOURCE_GROUP" --name "$VM" \
    --command-id RunShellScript --scripts "$1" --query 'value[0].message' --output tsv
}

usage() {
  printf '%s\n' \
    'Factory AI' \
    'Usage: factory COMMAND [ARGUMENTS]' \
    '' \
    'GET STARTED' \
    '  ui                         Open the interactive operator console' \
    '  setup                      Deploy or repair Factory AI on Azure' \
    '  doctor                     Check local and Azure configuration' \
    '' \
    'WORK' \
    '  workspace list             List imported workspaces' \
    '  workspace import SOURCE    Import a path or owner/repository' \
    '  workspace show NAME        Show workspace details' \
    '  workspace remove NAME      Remove a workspace from the catalog' \
    '  workspace sync enable NAME Enable automatic committed-change sync' \
    '  workspace sync now NAME    Synchronize a workspace immediately' \
    '  workspace sync status      Show synchronization state' \
    '  submit [--new] WORKSPACE OBJECTIVE  Queue an idempotent objective' \
    '  prompt WORKSPACE TEXT       Auto-route a prompt to a quick action or objective' \
    '  init PATH                  Add Factory instructions to a project' \
    '' \
    'OPERATE' \
    '  status                     Show runtime status' \
    '  dashboard                  Print the operator dashboard' \
    '  queue                      Show queue state' \
    '  logs                       Show recent service logs' \
    '  report                     Show the latest operator report' \
    '  usage report               Show local Factory AI token usage' \
    '  usage sync                 Synchronize the VM usage ledger' \
    '  usage export               Export factory.usage.v1 JSONL' \
    '  agent diff OBJECTIVE TASK  Show one agent worktree patch' \
    '  pause                      Stop dispatching new work' \
    '  resume                     Resume work dispatch' \
    '  shutdown                   Disable the complete runtime safely' \
    '  start                      Re-enable the complete runtime' \
    '' \
    'CONFIGURE' \
    '  models show                Show role-to-model routes' \
    '  models set ROLE ROUTE      Set a role model route' \
    '  models reset ROLE          Restore a role model route' \
    '  secret list                List secret metadata' \
    '  secret set NAME            Store a secret in Key Vault' \
    '  secret copy NAME           Copy a secret value to clipboard' \
    '  secret delete NAME         Delete a secret' \
    '  update check               Check for a newer release' \
    '  update now                 Install and deploy the latest release' \
    '  update status              Show automatic updater status' \
    '  update enable              Enable automatic updates' \
    '  update disable             Disable automatic updates' \
    '' \
    'INTEGRATE' \
    '  github status              Show GitHub connection status' \
    '  github connect ORG         Connect a GitHub organization' \
    '  github transfer REPO ORG   Transfer a repository' \
    '  telegram status            Show Telegram integration status' \
    '  telegram configure         Configure Telegram control' \
    '  telegram start             Start Telegram control' \
    '  telegram stop              Stop Telegram control' \
    '  approval approve ...       Approve a policy checkpoint' \
    '  approval deny ...          Deny a policy checkpoint' \
    '  acp REQUEST.json           Run an ACP request' \
    '  extension verify ...       Verify a signed extension' \
    '' \
    'TUI: Ctrl+K commands, Ctrl+W workspaces, Ctrl+S objectives, Ctrl+G agents.'
}

command=${1:-ui}
shift || true

apply_runtime_model() {
  local variable=$1 value=${2:-} mode=${3:-set} script settings
  script="set -euo pipefail; exec 9>/run/lock/factory-ai-config.lock; flock -x 9; first=/etc/agent-factory.env; second=/etc/agent-factory-control.env; backup_first=\$(mktemp); backup_second=\$(mktemp); cp --preserve=mode,ownership \"\$first\" \"\$backup_first\"; cp --preserve=mode,ownership \"\$second\" \"\$backup_second\"; rollback() { install -m 0640 -o root -g factory \"\$backup_first\" \"\$first\"; install -m 0640 -o root -g factory \"\$backup_second\" \"\$second\"; systemctl restart agent-factory-control agent-factory-worker agent-factory-release || true; rm -f \"\$backup_first\" \"\$backup_second\"; }; trap rollback ERR TERM INT; for file in \"\$first\" \"\$second\"; do tmp=\$(mktemp); grep -v '^${variable}=' \"\$file\" > \"\$tmp\" || true; if [[ '$mode' == set ]]; then printf '${variable}=%s\\n' '$value' >> \"\$tmp\"; fi; install -m 0640 -o root -g factory \"\$tmp\" \"\$file\"; rm -f \"\$tmp\"; done; systemctl restart agent-factory-control agent-factory-worker agent-factory-release; systemctl is-active --quiet agent-factory-control agent-factory-worker agent-factory-release; trap - ERR TERM INT; rm -f \"\$backup_first\" \"\$backup_second\""
  printf -v script 'bash -c %q' "$script"
  settings=$(jq -n --arg command "$script" '{commandToExecute:$command}')
  az vm extension set --resource-group "$RESOURCE_GROUP" --vm-name "$VM" --name CustomScript \
    --publisher Microsoft.Azure.Extensions --version 2.1 --force-update --protected-settings "$settings" --output none
}

update_local_model() {
  local variable=$1 value=${2:-} mode=${3:-set} temporary
  mkdir -p "$(dirname "$CONFIG_FILE")"
  temporary=$(mktemp "${CONFIG_FILE}.XXXXXX")
  if [[ -f $CONFIG_FILE ]]; then grep -v "^${variable}=" "$CONFIG_FILE" > "$temporary" || true
  elif [[ -f $LEGACY_CONFIG_FILE ]]; then grep -v "^${variable}=" "$LEGACY_CONFIG_FILE" > "$temporary" || true; fi
  if [[ $mode == set ]]; then printf '%s=%q\n' "$variable" "$value" >> "$temporary"; fi
  chmod 0600 "$temporary"
  mv "$temporary" "$CONFIG_FILE"
}

configure_model_transaction() {
  local variable=$1 value=${2:-} mode=${3:-set}
  MODEL_CONFIG_BACKUP=$(mktemp)
  MODEL_CONFIG_EXISTED=false
  if [[ -f $CONFIG_FILE ]]; then cp "$CONFIG_FILE" "$MODEL_CONFIG_BACKUP"; MODEL_CONFIG_EXISTED=true; fi
  rollback_local_model() {
    if [[ $MODEL_CONFIG_EXISTED == true ]]; then mv "$MODEL_CONFIG_BACKUP" "$CONFIG_FILE"; else rm -f "$CONFIG_FILE" "$MODEL_CONFIG_BACKUP"; fi
  }
  trap rollback_local_model EXIT INT TERM
  update_local_model "$variable" "$value" "$mode"
  apply_runtime_model "$variable" "$value" "$mode"
  rm -f "$MODEL_CONFIG_BACKUP"
  trap - EXIT INT TERM
}

vm_extension_command() {
  local script=$1 settings
  printf -v script 'bash -c %q' "$script"
  settings=$(jq -n --arg command "$script" '{commandToExecute:$command}')
  az vm extension set --resource-group "$RESOURCE_GROUP" --vm-name "$VM" --name CustomScript \
    --publisher Microsoft.Azure.Extensions --version 2.1 --force-update --protected-settings "$settings" --output none
  az vm extension show --resource-group "$RESOURCE_GROUP" --vm-name "$VM" --name CustomScript --instance-view --query 'instanceView.statuses[0].message' --output tsv
}

store_vault_secret() {
  local vault_name=$1 secret_name=$2 secret_value=$3 secret_file
  [[ -n $secret_value && $secret_value != *$'\n'* && $secret_value != *$'\r'* ]] || { printf 'Secret %s is empty or contains a newline.\n' "$secret_name" >&2; return 2; }
  secret_file=$(mktemp)
  chmod 0600 "$secret_file"
  printf '%s' "$secret_value" > "$secret_file"
  if az keyvault secret set --vault-name "$vault_name" --name "$secret_name" --file "$secret_file" --output none; then rm -f "$secret_file"; else rm -f "$secret_file"; return 1; fi
}

wait_for_vault_access() {
  local vault_name=$1
  for _ in $(seq 1 12); do
    az keyvault secret list --vault-name "$vault_name" --maxresults 1 --output none >/dev/null 2>&1 && return 0
    sleep 5
  done
  printf 'Timed out waiting for Key Vault network access: %s\n' "$vault_name" >&2
  return 1
}

case "$command" in
  update)
    action=${1:-check}
    case "$action" in
      check)
        current=$(node -p "require('$FACTORY_ROOT/package.json').version")
        latest=$(npm view factory-ai version)
        printf 'Local %s · latest %s\n' "$current" "$latest"
        ;;
      now)
        latest=$(npm view factory-ai version)
        current=$(node -p "require('$FACTORY_ROOT/package.json').version")
        current_major=${current%%.*}; latest_major=${latest%%.*}
        [[ $current_major == "$latest_major" ]] || { printf 'Major update %s -> %s requires an explicit migration release; local and Azure versions were not changed.\n' "$current" "$latest" >&2; exit 2; }
        if [[ $current != "$latest" ]]; then
          npm install --global "factory-ai@$latest"
          if ! vm_extension_command 'bash /opt/agent-factory/app/bootstrap/auto-update.sh'; then
            npm install --global "factory-ai@$current" || printf 'WARNING: local rollback to %s failed.\n' "$current" >&2
            printf 'Azure update failed; local CLI rollback to %s was attempted.\n' "$current" >&2
            exit 1
          fi
        fi
        deployed=$(vm_extension_command 'jq -c . /opt/agent-factory/state/runtime-version.json')
        grep -q "\"version\":\"$latest\"" <<<"$deployed" || { printf 'Azure runtime did not verify at %s; local version may require repair.\n' "$latest" >&2; exit 1; }
        installed=$(node -p "require('$(npm root -g)/factory-ai/package.json').version")
        [[ $installed == "$latest" ]] || { printf 'Local CLI verification failed: expected %s, found %s.\n' "$latest" "$installed" >&2; exit 1; }
        printf 'Factory AI is current at %s locally and on Azure.\n' "$latest"
        ;;
      status)
        vm_extension_command 'set -e; printf "timer enabled: "; systemctl is-enabled factory-ai-update.timer; printf "timer active: "; systemctl is-active factory-ai-update.timer; jq -c . /opt/agent-factory/state/runtime-version.json'
        ;;
      enable)
        vm_extension_command 'systemctl enable --now factory-ai-update.timer; systemctl is-active factory-ai-update.timer'
        ;;
      disable)
        vm_extension_command 'systemctl disable --now factory-ai-update.timer; systemctl is-active factory-ai-update.timer >/dev/null && exit 1 || true; printf "automatic updates disabled\n"'
        ;;
      *) printf 'Usage: factory update check | now | status | enable | disable\n' >&2; exit 2 ;;
    esac
    ;;
  approval)
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events exec node "$FACTORY_ROOT/src/approval-cli.js" "$@"
    ;;
  agent)
    [[ ${1:-} == diff && ${2:-} =~ ^[A-Za-z0-9_-]{1,64}$ && ${3:-} =~ ^[A-Za-z0-9_-]{1,64}$ && ( -z ${4:-} || ${4:-} == --json ) ]] || { printf 'Usage: factory agent diff OBJECTIVE_ID TASK_ID [--json]\n' >&2; exit 2; }
    published=$(remote "systemd-run --quiet --wait --pipe --collect --uid=factory --gid=factory --property=SupplementaryGroups=docker --property=WorkingDirectory=/opt/agent-factory/app /usr/bin/node /opt/agent-factory/app/src/run-with-env.js /etc/agent-factory.env /usr/bin/node /opt/agent-factory/app/src/agent-diff-publish.js '${2}' '${3}'")
    metadata=$(printf '%s' "$published" | node -e 'let value="";process.stdin.on("data",chunk=>value+=chunk).on("end",()=>{const matches=value.match(/\{"blob":"agent-diffs\/[a-f0-9-]{36}\.bin"[^}]+\}/g);if(!matches)process.exit(1);const item=JSON.parse(matches.at(-1));process.stdout.write([item.blob,item.key,item.iv,item.tag].join("\t"))})') || { printf 'Agent diff publication returned invalid metadata.\n' >&2; exit 1; }
    IFS=$'\t' read -r blob key iv tag <<<"$metadata"
    FACTORY_STORAGE_ACCOUNT="$STORAGE" exec node "$FACTORY_ROOT/src/agent-diff-download.js" "$STORAGE" "$blob" "$key" "$iv" "$tag" "${4:-}"
    ;;
  acp)
    request=${1:?ACP request JSON file required}
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events FACTORY_ACP_ENABLED=true exec node "$FACTORY_ROOT/src/acp-cli.js" "$request"
    ;;
  extension)
    [[ ${1:-} == verify ]] || { printf 'Usage: factory extension verify MANIFEST ARTIFACT PUBLIC_KEY\n' >&2; exit 2; }
    exec node "$FACTORY_ROOT/src/extension-cli.js" "${2:?manifest required}" "${3:?artifact required}" "${4:?public key required}"
    ;;
  workspace)
    exec node "$FACTORY_ROOT/src/workspace-cli.js" "$@"
    ;;
  configure)
    area=${1:-models}
    [[ $area == models ]] || { printf 'Supported configuration area: models\n' >&2; exit 2; }
    "$0" models show
    read -r -p 'Role to change (or Enter to leave unchanged): ' role
    [[ -n $role ]] || exit 0
    read -r -p 'New provider/model route (or "default"): ' route
    if [[ $route == default ]]; then exec "$0" models reset "$role"; fi
    exec "$0" models set "$role" "$route"
    ;;
  models)
    action=${1:-show}
    role=${2:-}
    route=${3:-}
    case "$action" in
      show)
        for current in scout planner builder tester debugger reviewer security release; do
          upper=$(printf '%s' "$current" | tr '[:lower:]' '[:upper:]')
          variable="FACTORY_MODEL_${upper}"
          case "$current" in
            scout) default=azureai-textved/factory-gpt-5-4-nano ;;
            tester) default=azureai-textved/gpt-5.4 ;;
            builder) default=azureai-textved/gpt-5.5 ;;
            *) default=azureai-textved/gpt-5.6-sol ;;
          esac
          printf '%-10s %s%s\n' "$current" "${!variable:-$default}" "$([[ -n ${!variable:-} ]] && printf ' (override)' || true)"
        done
        ;;
      set)
        [[ $role =~ ^(scout|planner|builder|tester|debugger|reviewer|security|release)$ ]] || { printf 'Invalid model role\n' >&2; exit 2; }
        node --input-type=module -e "import { validateModelRoute } from 'file://$FACTORY_ROOT/src/routing.js'; validateModelRoute(process.argv[1])" "$route"
        upper=$(printf '%s' "$role" | tr '[:lower:]' '[:upper:]')
        variable="FACTORY_MODEL_${upper}"
        configure_model_transaction "$variable" "$route" set
        printf '%s now routes to %s. Runtime services are healthy.\n' "$role" "$route"
        ;;
      reset)
        [[ $role =~ ^(scout|planner|builder|tester|debugger|reviewer|security|release)$ ]] || { printf 'Invalid model role\n' >&2; exit 2; }
        upper=$(printf '%s' "$role" | tr '[:lower:]' '[:upper:]')
        variable="FACTORY_MODEL_${upper}"
        configure_model_transaction "$variable" "" reset
        printf '%s restored to the versioned default. Runtime services are healthy.\n' "$role"
        ;;
      *) printf 'Usage: factory models show | set ROLE PROVIDER/MODEL | reset ROLE\n' >&2; exit 2 ;;
    esac
    ;;
  telegram)
    action=${1:-status}
    case "$action" in
      status) remote 'systemctl status agent-factory-telegram.service --no-pager -n 20' ;;
      start) remote 'systemctl restart agent-factory-telegram.service; systemctl is-active agent-factory-telegram.service' ;;
      stop) remote 'systemctl stop agent-factory-telegram.service' ;;
      configure)
        read -r -s -p 'Telegram bot token from @BotFather: ' telegram_token; printf '\n'
        read -r -p 'Allowed Telegram chat IDs (comma-separated): ' telegram_chat_ids
        [[ $telegram_chat_ids =~ ^-?[0-9]+(,-?[0-9]+)*$ ]] || { printf 'Invalid Telegram chat ID allowlist\n' >&2; exit 2; }
        ip=$(curl -fsS https://api.ipify.org)
        cleanup_telegram_vault() { az keyvault network-rule remove --name "$VAULT" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; }
        trap cleanup_telegram_vault EXIT
        az keyvault network-rule add --name "$VAULT" --ip-address "$ip/32" --output none
        wait_for_vault_access "$VAULT"
        store_vault_secret "$VAULT" telegram-bot-token "$telegram_token"
        store_vault_secret "$VAULT" telegram-allowed-chat-ids "$telegram_chat_ids"
        unset telegram_token
        remote 'systemctl restart agent-factory-telegram.service; systemctl is-active agent-factory-telegram.service'
        ;;
      *) printf 'Unknown telegram action: %s\n' "$action" >&2; exit 2 ;;
    esac
    ;;
  issue)
    repo=${1:?repository owner/name required}
    number=${2:?issue number required}
    [[ $repo =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ && $number =~ ^[0-9]+$ ]] || { printf 'Invalid repository or issue number\n' >&2; exit 2; }
    issue=$(gh issue view "$number" --repo "$repo" --json title,body,url)
    title=$(jq -r .title <<<"$issue")
    body=$(jq -r .body <<<"$issue")
    url=$(jq -r .url <<<"$issue")
    objective="/goal Resolve GitHub issue #$number: $title"
    objective+=$'\n\n'
    objective+="$body"
    objective+=$'\n\nSource: '
    objective+="$url"
    exec "$0" submit "$repo" "$objective"
    ;;
  ui)
    if ! config_ready; then
      "$0" setup
      exec "$0" ui
    fi
    phase=$(setup_phase)
    if [[ $phase == foundation_ready ]]; then
      printf 'Azure foundation exists, but the runtime is not deployed. Run `factory setup --deploy`, then `factory doctor`.\n' >&2
      exit 1
    fi
    if [[ $phase != complete && $phase != legacy ]]; then
      "$0" setup
      exec "$0" ui
    fi
    version=$(node -p "require('$FACTORY_ROOT/package.json').version")
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch=$(uname -m)
    [[ $arch == x86_64 ]] && arch=amd64
    [[ $arch == aarch64 ]] && arch=arm64
    cache="$HOME/.cache/factory-ai/$version"
    binary="$cache/factory-ui-$os-$arch"
    if [[ ! -x $binary ]]; then
      mkdir -p "$cache"
      base="https://github.com/itsvedantkumar/factory-ai/releases/download/v$version"
      if curl -fsSL "$base/factory-ui-$os-$arch" -o "$binary.tmp" && curl -fsSL "$base/checksums.txt" -o "$cache/checksums.txt"; then
        expected=""
        while read -r checksum asset; do [[ $asset == "factory-ui-$os-$arch" ]] && expected=$checksum; done < "$cache/checksums.txt"
        actual=""
        if command -v shasum >/dev/null; then actual=$(shasum -a 256 "$binary.tmp"); actual=${actual%% *};
        elif command -v sha256sum >/dev/null; then actual=$(sha256sum "$binary.tmp"); actual=${actual%% *}; fi
        if [[ -n $expected && $actual == "$expected" ]] && gh attestation verify "$binary.tmp" --repo itsvedantkumar/factory-ai >/dev/null 2>&1; then mv "$binary.tmp" "$binary"; chmod 0755 "$binary"; else rm -f "$binary.tmp"; fi
      fi
    fi
    if [[ -x $binary ]]; then
      FACTORY_STORAGE_ACCOUNT="$STORAGE" FACTORY_NAME="$FACTORY_NAME" FACTORY_PURPOSE="$FACTORY_PURPOSE" exec "$binary"
    fi
    printf 'Verified Factory TUI binary is unavailable for %s/%s. Check GitHub release assets and `gh auth status`.\n' "$os" "$arch" >&2
    exit 1
    ;;
  setup)
    if [[ ${1:-} == --status ]]; then
      phase=not_started
      onboarding_complete=false
      if [[ -f $SETUP_STATE_FILE ]]; then
        phase=$(jq -r '.phase // "unknown"' "$SETUP_STATE_FILE")
        onboarding_complete=$(jq -r '.onboardingComplete // false' "$SETUP_STATE_FILE")
      elif config_ready; then
        phase=legacy
      fi
      ready=false; config_ready && ready=true
      runtime_ready=false; [[ $ready == true && ( $phase == complete || $phase == legacy ) ]] && runtime_ready=true
      jq -n --arg phase "$phase" --argjson onboardingComplete "$onboarding_complete" --argjson configReady "$ready" --argjson runtimeReady "$runtime_ready" '{phase:$phase,onboardingComplete:$onboardingComplete,configReady:$configReady,runtimeReady:$runtimeReady}'
      exit 0
    fi
    for dependency in az gh jq curl ssh-keygen node; do command -v "$dependency" >/dev/null || { printf 'Missing dependency: %s\n' "$dependency" >&2; exit 1; }; done
    mkdir -p "$(dirname "$CONFIG_FILE")"
    setup_lock="$(dirname "$CONFIG_FILE")/setup.lock"
    if ! ln -s "$$" "$setup_lock" 2>/dev/null; then
      setup_pid=$(readlink "$setup_lock" 2>/dev/null || true)
      if [[ $setup_pid =~ ^[0-9]+$ ]] && kill -0 "$setup_pid" 2>/dev/null; then
        printf 'Factory setup is already running as process %s.\n' "$setup_pid" >&2
      else
        printf 'A stale setup lock exists at %s. Verify no setup process is running, then remove that symlink and retry.\n' "$setup_lock" >&2
      fi
      exit 1
    fi
    [[ ${1:-} == --reset ]] && rm -f "$SETUP_STATE_FILE"
    choices=$(mktemp)
    cleanup_setup_files() { rm -f "$choices"; [[ $(readlink "$setup_lock" 2>/dev/null || true) == "$$" ]] && rm -f "$setup_lock" || true; }
    trap cleanup_setup_files EXIT
    trap 'cleanup_setup_files; exit 130' INT TERM
    node "$FACTORY_ROOT/src/setup-menu.js" "$choices" "$SETUP_STATE_FILE" "${1:-}"
    provider=$(jq -r .provider "$choices")
    factory_name=$(jq -r .factoryName "$choices")
    factory_purpose=$(jq -r .factoryPurpose "$choices")
    location=$(jq -r .location "$choices")
    enterprise_org=$(jq -r .githubOrg "$choices")
    aws_region=$(jq -r .awsRegion "$choices")
    bedrock_builder=$(jq -r .bedrockBuilderModel "$choices")
    deploy_now=$(jq -r .deployNow "$choices")
    telegram=$(jq -r .telegram "$choices")
    skip_credentials=false
    phase=$(setup_phase)
    if [[ ${1:-} != --reset ]] && config_ready && [[ $phase == foundation || $phase == credentials_ready || $phase == foundation_ready ]]; then
      vault=$VAULT
      namespace=$NAMESPACE
      storage=$STORAGE
      [[ $phase == credentials_ready || $phase == foundation_ready ]] && skip_credentials=true
    else
    az account show --query '{subscription:name,state:state}' --output table
    gh auth status
    if az group show --name "$RESOURCE_GROUP" --output none 2>/dev/null; then
      location=$(az group show --name "$RESOURCE_GROUP" --query location --output tsv)
    else
      az group create --name "$RESOURCE_GROUP" --location "$location" --output none
    fi
    key=${FACTORY_SSH_KEY:-$HOME/.ssh/agent-factory-azure}
    [[ -f $key ]] || ssh-keygen -t ed25519 -f "$key" -N "" -C agent-factory-azure
    [[ -f $key.pub ]] || { ssh-keygen -y -f "$key" > "$key.pub"; chmod 0644 "$key.pub"; }
    operator=$(az ad signed-in-user show --query id --output tsv)
    deployment=$(az deployment group create --name agent-factory-setup --resource-group "$RESOURCE_GROUP" --template-file "$FACTORY_ROOT/infra/main.bicep" --parameters adminSshKey="$(< "$key.pub")" operatorObjectId="$operator" --output json)
    vault=$(jq -r '.properties.outputs.keyVaultName.value' <<<"$deployment")
    namespace=$(jq -r '.properties.outputs.serviceBusNamespace.value' <<<"$deployment")
    storage=$(jq -r '.properties.outputs.storageAccount.value' <<<"$deployment")
    VAULT=$vault
    NAMESPACE=$namespace
    config_temporary=$(mktemp "${CONFIG_FILE}.XXXXXX")
    if [[ -f $CONFIG_FILE ]]; then
      grep -Ev '^FACTORY_(RESOURCE_GROUP|VM|SERVICE_BUS|KEY_VAULT|STORAGE_ACCOUNT|NAME|PURPOSE)=' "$CONFIG_FILE" > "$config_temporary" || true
    elif [[ -f $LEGACY_CONFIG_FILE ]]; then
      grep -Ev '^FACTORY_(RESOURCE_GROUP|VM|SERVICE_BUS|KEY_VAULT|STORAGE_ACCOUNT|NAME|PURPOSE)=' "$LEGACY_CONFIG_FILE" > "$config_temporary" || true
    fi
    {
      printf 'FACTORY_RESOURCE_GROUP=%q\n' "$RESOURCE_GROUP"
      printf 'FACTORY_VM=%q\n' agent-factory-vm
      printf 'FACTORY_SERVICE_BUS=%q\n' "$namespace"
      printf 'FACTORY_KEY_VAULT=%q\n' "$vault"
      printf 'FACTORY_STORAGE_ACCOUNT=%q\n' "$storage"
      printf 'FACTORY_NAME=%q\n' "$factory_name"
      printf 'FACTORY_PURPOSE=%q\n' "$factory_purpose"
    } >> "$config_temporary"
    chmod 0600 "$config_temporary"
    mv "$config_temporary" "$CONFIG_FILE"
    state_temporary=$(mktemp "${SETUP_STATE_FILE}.XXXXXX")
    jq '.phase="foundation" | .updatedAt=(now|todateiso8601)' "$SETUP_STATE_FILE" > "$state_temporary"
    chmod 0600 "$state_temporary"
    mv "$state_temporary" "$SETUP_STATE_FILE"
    fi
    if [[ $skip_credentials != true ]]; then
    ip=$(curl -fsS https://api.ipify.org)
    cleanup_setup_vault() { az keyvault network-rule remove --name "$vault" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; cleanup_setup_files; }
    trap cleanup_setup_vault EXIT
    az keyvault network-rule add --name "$vault" --ip-address "$ip/32" --output none
    wait_for_vault_access "$vault"
    github_token=$(gh auth token)
    store_vault_secret "$vault" github-token "$github_token"
    unset github_token
    if [[ -n $enterprise_org ]]; then
      gh api "orgs/$enterprise_org" --silent
      store_vault_secret "$vault" github-enterprise-org "$enterprise_org"
    fi
    if [[ $provider == azure || $provider == both ]]; then
      read -r -p 'Azure OpenAI-compatible base URL: ' azure_base
      read -r -s -p 'Azure API key: ' azure_key; printf '\n'
      [[ $azure_base =~ ^https://[^[:space:]]+$ && -n $azure_key ]] || { printf 'A valid HTTPS Azure base URL and non-empty API key are required.\n' >&2; exit 2; }
      azure_small_base=$azure_base
      azure_small_key=$azure_key
      store_vault_secret "$vault" azure-primary-base-url "$azure_base"
      store_vault_secret "$vault" azure-primary-api-key "$azure_key"
      store_vault_secret "$vault" azure-small-base-url "$azure_small_base"
      store_vault_secret "$vault" azure-small-api-key "$azure_small_key"
      unset azure_key azure_small_key
    fi
    if [[ $provider == bedrock || $provider == both ]]; then
      read -r -p 'AWS access key ID: ' aws_access_key
      read -r -s -p 'AWS secret access key: ' aws_secret_key; printf '\n'
      read -r -s -p 'AWS session token (optional): ' aws_session_token; printf '\n'
      [[ -n $aws_access_key && -n $aws_secret_key ]] || { printf 'AWS access key ID and secret access key are required.\n' >&2; exit 2; }
      store_vault_secret "$vault" aws-access-key-id "$aws_access_key"
      store_vault_secret "$vault" aws-secret-access-key "$aws_secret_key"
      [[ -n $aws_session_token ]] && store_vault_secret "$vault" aws-session-token "$aws_session_token"
      unset aws_access_key aws_secret_key aws_session_token
    fi
    if [[ $telegram == true ]]; then
      read -r -s -p 'Telegram bot token from @BotFather: ' telegram_token; printf '\n'
      read -r -p 'Allowed Telegram chat IDs (comma-separated): ' telegram_chat_ids
      [[ -n $telegram_token && $telegram_chat_ids =~ ^-?[0-9]+(,-?[0-9]+)*$ ]] || { printf 'A bot token and valid Telegram chat ID allowlist are required.\n' >&2; exit 2; }
      store_vault_secret "$vault" telegram-bot-token "$telegram_token"
      store_vault_secret "$vault" telegram-allowed-chat-ids "$telegram_chat_ids"
      unset telegram_token
    fi
    fi
    if [[ $skip_credentials != true ]]; then
      state_temporary=$(mktemp "${SETUP_STATE_FILE}.XXXXXX")
      jq '.phase="credentials_ready" | .updatedAt=(now|todateiso8601)' "$SETUP_STATE_FILE" > "$state_temporary"
      chmod 0600 "$state_temporary"
      mv "$state_temporary" "$SETUP_STATE_FILE"
    fi
    printf 'Azure foundation and credential vault ready. Config: %s\n' "$CONFIG_FILE"
    if [[ $deploy_now == true ]]; then
      installed_version=$(node -p "require('$FACTORY_ROOT/package.json').version")
      source_ref=$(npm view "factory-ai@$installed_version" gitHead)
      [[ $source_ref =~ ^[a-f0-9]{40}$ ]] || { printf 'Published package %s has no valid source commit provenance.\n' "$installed_version" >&2; exit 1; }
      tag_ref=$(gh api "repos/itsvedantkumar/factory-ai/commits/v$installed_version" --jq .sha)
      [[ $tag_ref == "$source_ref" ]] || { printf 'Release tag and npm package provenance disagree for %s.\n' "$installed_version" >&2; exit 1; }
      parameters=(KEY_VAULT_NAME "$vault" SERVICE_BUS_NAMESPACE "$namespace" FACTORY_STORAGE_ACCOUNT "$storage" FACTORY_NAME "$factory_name" FACTORY_PURPOSE "$factory_purpose" SOURCE_REPOSITORY itsvedantkumar/factory-ai SOURCE_REF "$source_ref")
      if [[ $provider == bedrock ]]; then
        parameters+=(AWS_REGION "$aws_region")
        for role in SCOUT PLANNER BUILDER TESTER DEBUGGER REVIEWER SECURITY RELEASE; do parameters+=("FACTORY_MODEL_$role" "bedrock/$bedrock_builder"); done
      elif [[ $provider == both ]]; then
        parameters+=(AWS_REGION "$aws_region" FACTORY_MODEL_BUILDER "bedrock/$bedrock_builder")
      fi
      az vm run-command invoke --resource-group "$RESOURCE_GROUP" --name agent-factory-vm --command-id RunShellScript \
        --scripts @"$FACTORY_ROOT/bootstrap/deploy-runtime.sh" --parameters "${parameters[@]}" --output none
      remote 'set -e; systemctl is-active --quiet agent-factory-control agent-factory-worker agent-factory-release; sudo -u factory node /opt/agent-factory/app/src/run-with-env.js /etc/agent-factory-control.env node /opt/agent-factory/app/src/provider-doctor.js'
      printf 'Runtime deployed. Run: factory doctor && factory dashboard\n'
    fi
    state_temporary=$(mktemp "${SETUP_STATE_FILE}.XXXXXX")
    jq --arg deployed "$deploy_now" '.phase=(if $deployed == "true" then "complete" else "foundation_ready" end) | .updatedAt=(now|todateiso8601)' "$SETUP_STATE_FILE" > "$state_temporary"
    chmod 0600 "$state_temporary"
    mv "$state_temporary" "$SETUP_STATE_FILE"
    ;;
  github)
    action=${1:-status}
    case "$action" in
      status)
        gh auth status
        printf 'Organizations:\n'
        gh api user/orgs --jq '.[].login'
        ;;
      connect)
        org=${2:?Enterprise organization required}
        gh api "orgs/$org" --jq '{login,plan:.plan.name}'
        token=$(gh auth token)
        ip=$(curl -fsS https://api.ipify.org)
        cleanup_github_vault() { az keyvault network-rule remove --name "$VAULT" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; }
        trap cleanup_github_vault EXIT
        az keyvault network-rule add --name "$VAULT" --ip-address "$ip/32" --output none
        wait_for_vault_access "$VAULT"
        store_vault_secret "$VAULT" github-token "$token"
        store_vault_secret "$VAULT" github-enterprise-org "$org"
        unset token
        printf 'Connected organization %s. Restart release/worker services after credential changes.\n' "$org"
        ;;
      transfer)
        repo=${2:?OWNER/REPO required}
        org=${3:?Enterprise organization required}
        gh api --method POST "repos/$repo/transfer" -f new_owner="$org" --silent
        printf 'Transfer requested: %s -> %s. Update submit paths after GitHub completes it.\n' "$repo" "$org"
        ;;
      *) printf 'Unknown github action: %s\n' "$action" >&2; exit 2 ;;
    esac
    ;;
  secret)
    action=${1:-list}
    name=${2:-}
    ip=$(curl -fsS https://api.ipify.org)
    cleanup_vault_rule() { az keyvault network-rule remove --name "$VAULT" --ip-address "$ip/32" --output none >/dev/null 2>&1 || true; }
    trap cleanup_vault_rule EXIT
    az keyvault network-rule add --name "$VAULT" --ip-address "$ip/32" --output none
    wait_for_vault_access "$VAULT"
    case "$action" in
      list) az keyvault secret list --vault-name "$VAULT" --query '[].{name:name,updated:attributes.updated}' --output table ;;
      set)
        [[ $name =~ ^[A-Za-z0-9-]+$ ]] || { printf 'Valid secret name required\n' >&2; exit 2; }
        read -r -s -p "Value for $name: " value
        printf '\n'
        store_vault_secret "$VAULT" "$name" "$value"
        unset value
        printf 'Stored %s in Azure Key Vault.\n' "$name"
        ;;
      copy)
        [[ $name =~ ^[A-Za-z0-9-]+$ ]] || { printf 'Valid secret name required\n' >&2; exit 2; }
        az keyvault secret show --vault-name "$VAULT" --name "$name" --query value --output tsv | pbcopy
        printf 'Copied %s to clipboard without printing it.\n' "$name"
        ;;
      delete)
        [[ $name =~ ^[A-Za-z0-9-]+$ ]] || { printf 'Valid secret name required\n' >&2; exit 2; }
        az keyvault secret delete --vault-name "$VAULT" --name "$name" --output none
        printf 'Soft-deleted %s.\n' "$name"
        ;;
      *) printf 'Unknown secret action: %s\n' "$action" >&2; exit 2 ;;
    esac
    ;;
  init)
    target=${1:?local project path required}
    [[ -d $target ]] || { printf 'Project directory does not exist: %s\n' "$target" >&2; exit 2; }
    context=$(node --input-type=module -e "import { initializeProject } from 'file://$FACTORY_ROOT/src/project-init.js'; console.log(await initializeProject(process.argv[1], '$FACTORY_ROOT/templates'))" "$target")
    printf 'Initialized %s\nShared runtime memory remains on Azure; repo context lives in .agent-factory/.\n' "$context"
    ;;
  submit)
    [[ $# -ge 2 ]] || { printf 'Usage: factory submit [--new] WORKSPACE objective\n' >&2; exit 2; }
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events exec node "$FACTORY_ROOT/src/submit-cli.js" "$@"
    ;;
  prompt)
    [[ $# -ge 2 ]] || { printf 'Usage: factory prompt WORKSPACE text\n' >&2; exit 2; }
    SERVICE_BUS_NAMESPACE="$NAMESPACE" CONTROL_QUEUE=control-events exec node "$FACTORY_ROOT/src/prompt-cli.js" "$@"
    ;;
  sandbox)
    action=${1:-}
    shift || true
    [[ $action == run && $# -ge 3 ]] || { printf 'Usage: factory sandbox run WORKSPACE [--preview] -- COMMAND [ARGS]\n' >&2; exit 2; }
    FACTORY_ROOT="$FACTORY_ROOT" exec node "$FACTORY_ROOT/src/local-sandbox-cli.js" "$@"
    ;;
  dashboard|status)
    remote 'sudo -u factory node /opt/agent-factory/app/src/run-with-env.js /etc/agent-factory-control.env node /opt/agent-factory/app/src/dashboard.js'
    ;;
  queue)
    az servicebus queue list --resource-group "$RESOURCE_GROUP" --namespace-name "$NAMESPACE" \
      --query '[].{queue:name,active:countDetails.activeMessageCount,deadLetter:countDetails.deadLetterMessageCount}' --output table
    ;;
  report)
    remote 'node -e '\''const fs=require("fs"),p="/opt/agent-factory/state/reports";const f=fs.readdirSync(p).filter(x=>x.endsWith(".md")).sort().at(-1);process.stdout.write(fs.readFileSync(`${p}/${f}`,"utf8"))'\'''
    ;;
  usage)
    FACTORY_STORAGE_ACCOUNT="$STORAGE" exec node "$FACTORY_ROOT/src/usage-cli.js" "$@"
    ;;
  logs)
    remote 'journalctl -u agent-factory-control -u agent-factory-worker -u agent-factory-release --since "1 hour ago" --no-pager -n 250'
    ;;
  doctor)
    remote 'set -e; systemctl is-active agent-factory-control agent-factory-worker agent-factory-release; systemctl is-enabled agent-factory-reporter.timer; docker ps --format "{{.Names}} {{.Status}}"; findmnt /opt/agent-factory/state; df -h /opt/agent-factory/state; free -h; sudo -u factory node /opt/agent-factory/app/src/run-with-env.js /etc/agent-factory-control.env node /opt/agent-factory/app/src/provider-doctor.js'
    ;;
  pause)
    remote 'systemctl stop agent-factory-worker agent-factory-release'
    ;;
  resume)
    remote 'systemctl start agent-factory-worker agent-factory-release; systemctl is-active agent-factory-worker agent-factory-release'
    ;;
  shutdown)
    remote 'systemctl stop agent-factory-worker.service agent-factory-control.service agent-factory-release.service agent-factory-reporter.timer agent-factory-telegram.service factory-ai-update.timer factory-ai-snapshot.timer factory-ai-watchdog.timer factory-ai-qdrant.service factory-ai-ollama.service; printf "Factory runtime stopped with enablement preferences preserved. Azure VM and storage remain allocated and billable.\n"'
    ;;
  start)
    remote 'set -e; for unit in factory-ai-container-firewall.service agent-factory-control.service agent-factory-worker.service agent-factory-release.service agent-factory-reporter.timer agent-factory-telegram.service factory-ai-update.timer factory-ai-snapshot.timer factory-ai-watchdog.timer factory-ai-qdrant.service factory-ai-ollama.service; do systemctl is-enabled --quiet "$unit" && systemctl start "$unit" || true; done; systemctl is-active agent-factory-control agent-factory-worker agent-factory-release'
    ;;
  help|-h|--help) usage ;;
  *) usage >&2; exit 2 ;;
esac
