{
  "$schema": "https://opencode.ai/config.json",
  "model": "azureai-textved/gpt-5.6-sol",
  "small_model": "azureai-responses/gpt-5.4",
  "share": "disabled",
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "external_directory": "deny",
    "doom_loop": "deny",
    "question": "deny",
    "bash": {
      "*": "deny",
      "git *": "allow",
      "git push": "deny",
      "git push *": "deny",
      "git * push *": "deny",
      "gh *": "deny",
      "node *": "allow",
      "npm run *": "allow",
      "npm test*": "allow",
      "npx --no-install *": "allow",
      "rg *": "allow",
      "ls*": "allow",
      "pwd": "allow"
    }
  },
  "provider": {
    "azureai-textved": {
      "name": "Azure OpenAI engineering",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:TEXTVED_AZURE_BASE_URL}",
        "apiKey": "{env:TEXTVED_AZURE_API_KEY}",
        "timeout": 180000
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Solution"
        }
      }
    },
    "azureai-responses": {
      "name": "Azure OpenAI lightweight",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:AZURE_OPENAI_BASE_URL}",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "timeout": 180000
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4"
        }
      }
    }
  },
  "instructions": [
    "/opt/agent-factory/app/config/agent-instructions.md"
  ]
}
