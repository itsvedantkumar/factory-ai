[Unit]
Description=Azure Agent Factory capability-free control plane
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=factory
Group=factory
WorkingDirectory=/opt/agent-factory/app
EnvironmentFile=/etc/agent-factory-control.env
ExecStart=/usr/bin/node /opt/agent-factory/app/src/control-service.js
Restart=on-failure
RestartSec=10
TimeoutStopSec=45
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
LockPersonality=true
RestrictSUIDSGID=true
ReadWritePaths=/opt/agent-factory/state
UMask=0027

[Install]
WantedBy=multi-user.target
